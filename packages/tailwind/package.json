{
  "name": "@duo-icons/tailwind",  
  "version": "1.0.1",
  "author": "fazdiu",
  "license": "MIT",
  "description": "Duo Icons is a library of modern and beautiful duotone icons, designed for easy use in projects",
  "keywords": [
    "duotone",
    "icons",
    "open",
    "source",
    "tailwind icons",
    "css",
    "html",
    "duotone icons open source"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "types": "./dist/plugin.d.ts",
  "main": "./dist/plugin.cjs",
  "module": "./dist/plugin.js",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "require": "./dist/plugin.cjs"
    },
    "./icons": "./dist/icons.css",
    "./base": "./dist/base.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.js",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.5",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fazdiu/duo-icons.git"
  },
  "bugs": {
    "url": "https://github.com/fazdiu/duo-icons/issues"
  },
  "homepage": "https://github.com/fazdiu/duo-icons#readme"
}