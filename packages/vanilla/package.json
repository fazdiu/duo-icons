{
  "name": "duo-icons",
  "version": "2.0.1",
  "author": "fazdiu (formerly fernandcf)",
  "license": "MIT",
  "description": "Duo Icons is a library of modern and beautiful duotone icons, designed for easy use in projects",
  "keywords": [
    "duotone",
    "icons",
    "open",
    "source",
    "tailwind icons",
    "css",
    "html",
    "duotone icons open source"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    },
    "./plugin": {
      "require": "./plugin.js"
    }
  },
  "unpkg": "./dist/index.umd.cjs",
  "jsdelivr": "./dist/index.umd.cjs",
  "files": [
    "plugin.js",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "rebuild:icons": "npx tsx icons.rebuild.ts",
    "create-json:icons": "npx tsx ./scripts/icons.create.json.ts",
    "preview": "vite preview",
    "dev": "npm run create-json:icons && vite",
    "build": "npm run create-json:icons && vite build"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.4.0",
    "jsdom": "^28.1.0",
    "svgo": "^4.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fazdiu/duo-icons.git"
  },
  "bugs": {
    "url": "https://github.com/fazdiu/duo-icons/issues"
  },
  "homepage": "https://github.com/fazdiu/duo-icons#readme"
}