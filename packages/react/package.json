{
  "name": "@duo-icons/react",
  "author": "fazdiu",
  "description": "Duo Icons a curated collection of elegant duotone icons for React, built for developers who care about modern UI/UX",
  "license": "MIT",
  "version": "1.0.1",
  "keywords": [
    "duotone",
    "icons",
    "open",
    "source",
    "tailwind icons",
    "css",
    "html",
    "duotone icons open source"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fazdiu/duo-icons.git"
  },
  "bugs": {
    "url": "https://github.com/fazdiu/duo-icons/issues"
  },
  "homepage": "https://github.com/fazdiu/duo-icons#readme"
