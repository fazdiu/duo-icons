{
  "name": "duo-icons",
  "private": false,
  "version": "1.1.4",
  "module": "./dist/duo-icons.mjs",
  "main": "./dist/duo-icons.umd.js",
  "unpkg": "./dist/duo-icons.umd.js",
  "exports": {
    ".": {
      "import": "./dist/duo-icons.mjs",
      "require": "./dist/duo-icons.umd.js"
    },
    "./plugin": {
      "require": "./plugin.js"
    }
  },
  "files": [
    "dist",
    "plugin.js",
    "README.md"
  ],
  "scripts": {
    "rebuild:icons": "node icons.rebuild.js",
    "create-json:icons": "node icons.create.json.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "fs": "^0.0.1-security",
    "jsdom": "^28.1.0",
    "path": "^0.12.7",
    "svgo": "^3.0.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "description": "Duo Icons is a library of modern and beautiful duotone icons, designed for easy use in projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fazdiu/duo-icons.git"
  },
  "keywords": [
    "duotone",
    "icons",
    "open",
    "source",
    "tailwind icons",
    "css",
    "html",
    "duotone icons open source"
  ],
  "author": "fazdiu (formerly fernandcf)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/fazdiu/duo-icons/issues"
  },
  "homepage": "https://github.com/fazdiu/duo-icons#readme"
}
